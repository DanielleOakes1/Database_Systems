-- creating the tables

CREATE TABLE DIRECTOR (
    director_id NUMBER(7),
    name VARCHAR2(50),
    experience_years NUMBER(3),
    nationality VARCHAR2(30)
);

CREATE TABLE MOVIE (
    movie_id NUMBER(5),
    title VARCHAR2(50),
    release_year NUMBER(4),
    alt_title VARCHAR2(50),
    mpaa_rating VARCHAR2(3),
    description VARCHAR2(250),
    runtime NUMBER(4)
);

CREATE TABLE ACTOR (
    actor_id NUMBER(5),
    name VARCHAR2(75),
    date_of_birth DATE,
    nationality VARCHAR2(75)
);

CREATE TABLE CHARACTER_t (
    character_id NUMBER(5),
    alignment VARCHAR2(25),
    name VARCHAR2(50),
    species VARCHAR2(50)
);

CREATE TABLE  PRODUCTION_COMPANY(
    company_id NUMBER(5),
    company_name VARCHAR2(50),
    headquarters VARCHAR2(100)
);

CREATE TABLE  AWARD(
    award_id NUMBER(5),
    name VARCHAR2(50),
    category VARCHAR2(50)
);

CREATE TABLE REVIEW (
    movie_id NUMBER(5),
    review_no NUMBER(6),
    rating_score NUMBER(2,1),
    review_title VARCHAR2(100),
    review_text VARCHAR2(1000)
);


-- adding primary keys
ALTER TABLE DIRECTOR
ADD CONSTRAINT director_pk PRIMARY KEY (director_id);

ALTER TABLE MOVIE
ADD CONSTRAINT movie_pk PRIMARY KEY (movie_id);

ALTER TABLE REVIEW
ADD CONSTRAINT review_pk PRIMARY KEY (review_no);


ALTER TABLE ACTOR
ADD CONSTRAINT actor_pk PRIMARY KEY (actor_id);

ALTER TABLE CHARACTER_t
ADD CONSTRAINT character_t_pk PRIMARY KEY (character_id);

ALTER TABLE PRODUCTION_COMPANY
ADD CONSTRAINT production_company_pk PRIMARY KEY (company_id);

ALTER TABLE AWARD
ADD CONSTRAINT award_pk PRIMARY KEY (award_id);

-- adding missing columns
ALTER TABLE MOVIE
